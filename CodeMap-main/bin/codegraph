#!/usr/bin/env bash
# codegraph - platform-detecting wrapper with multi-level binary discovery
# Lookup order: PATH > ~/.codemap/bin/ > local dir > dev build > auto-download

set -euo pipefail

case "$(uname -s 2>/dev/null)" in
  Linux*)   _OS="linux" ;;
  Darwin*)  _OS="macos" ;;
  MINGW*|MSYS*|CYGWIN*) _OS="windows" ;;
  *)
    echo "[CodeMap] Unsupported OS: $(uname -s)" >&2
    exit 1
    ;;
esac

case "$(uname -m 2>/dev/null)" in
  x86_64|amd64)  _ARCH="x86_64" ;;
  aarch64|arm64) _ARCH="aarch64" ;;
  *)
    echo "[CodeMap] Unsupported architecture: $(uname -m)" >&2
    exit 1
    ;;
esac

_BIN_NAME="codegraph-${_ARCH}-${_OS}"
if [ "$_OS" = "windows" ]; then
  _BIN_NAME="${_BIN_NAME}.exe"
fi

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
CODEMAP_HOME="${CODEMAP_HOME:-$HOME/.codemap}"
CODEMAP_BIN_DIR="${CODEMAP_HOME}/bin"
GITHUB_REPO="killvxk/CodeMap"

_BIN=""

if command -v "$_BIN_NAME" >/dev/null 2>&1; then
  _BIN="$(command -v "$_BIN_NAME")"
fi

if [ -z "$_BIN" ] && [ -f "${CODEMAP_BIN_DIR}/${_BIN_NAME}" ]; then
  _BIN="${CODEMAP_BIN_DIR}/${_BIN_NAME}"
fi

if [ -z "$_BIN" ] && [ -f "${SCRIPT_DIR}/${_BIN_NAME}" ]; then
  _BIN="${SCRIPT_DIR}/${_BIN_NAME}"
fi

if [ -z "$_BIN" ]; then
  _DEV_NAME="codegraph"
  [ "$_OS" = "windows" ] && _DEV_NAME="codegraph.exe"
  for _CANDIDATE in \
    "${REPO_ROOT}/rust-cli/target/release/${_DEV_NAME}" \
    "${REPO_ROOT}/rust-cli/target/debug/${_DEV_NAME}" \
    "./rust-cli/target/release/${_DEV_NAME}" \
    "./rust-cli/target/debug/${_DEV_NAME}"
  do
    if [ -f "$_CANDIDATE" ]; then
      _BIN="$_CANDIDATE"
      break
    fi
  done
fi

if [ -z "$_BIN" ]; then
  echo "[CodeMap] codegraph binary (${_BIN_NAME}) not found; downloading from GitHub Releases..." >&2

  _DOWNLOAD_URL="https://github.com/${GITHUB_REPO}/releases/latest/download/${_BIN_NAME}"

  mkdir -p "$CODEMAP_BIN_DIR"
  _TARGET="${CODEMAP_BIN_DIR}/${_BIN_NAME}"

  if command -v curl >/dev/null 2>&1; then
    curl -fSL --progress-bar -o "$_TARGET" "$_DOWNLOAD_URL"
  elif command -v wget >/dev/null 2>&1; then
    wget -q --show-progress -O "$_TARGET" "$_DOWNLOAD_URL"
  else
    echo "[CodeMap] Download failed: curl or wget not found" >&2
    echo "[CodeMap] Download manually: ${_DOWNLOAD_URL}" >&2
    echo "[CodeMap] Place it in one of these locations:" >&2
    echo "[CodeMap]   1. ~/.codemap/bin/${_BIN_NAME}" >&2
    echo "[CodeMap]   2. PATH 中的任意目录" >&2
    exit 1
  fi

  if [ $? -ne 0 ] || [ ! -f "$_TARGET" ]; then
    echo "[CodeMap] Download failed, please fetch manually: ${_DOWNLOAD_URL}" >&2
    rm -f "$_TARGET"
    exit 1
  fi

  chmod +x "$_TARGET"
  echo "[CodeMap] Downloaded to ${_TARGET}" >&2
  _BIN="$_TARGET"
fi

exec "$_BIN" "$@"
